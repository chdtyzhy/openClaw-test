# Fastlane Matchfile - 证书和配置文件管理

# Git仓库URL (存储证书和配置文件)
git_url "https://github.com/yourusername/certificates-repo.git"

# 存储类型
storage_mode "git"

# Git分支
git_branch "main"

# 应用标识符
app_identifier "com.yourcompany.calculatorpro"

# 用户名 (Apple ID)
username "your-apple-id@email.com"

# 团队ID
team_id "YOUR_DEVELOPER_TEAM_ID"

# 团队名称
team_name "Your Team Name"

# 证书类型
type "appstore" # 默认使用App Store证书

# 是否只读模式 (true: 只下载, false: 可创建)
readonly false

# 密钥链设置
keychain_name "login.keychain"
keychain_password "" # 可选

# 平台
platform "ios"

# 是否强制匹配
force false

# 是否强制创建新的证书
force_for_new_devices false

# 跳过证书确认
skip_confirmation false

# 跳过证书下载
skip_docs false

# 共享值 (用于团队共享)
shallow_clone false
clone_branch_directly false

# 工作目录
workspace "./"

# 验证SSL
ssl_verify true

# 超时设置
timeout 300

# 详细输出
verbose true

# 额外配置
# 对于开发证书:
# match(type: "development", app_identifier: "com.yourcompany.calculatorpro")

# 对于AdHoc证书:
# match(type: "adhoc", app_identifier: "com.yourcompany.calculatorpro")

# 对于企业证书:
# match(type: "enterprise", app_identifier: "com.yourcompany.calculatorpro")