# Fastlane Appfile - 应用配置

# Apple ID (App Store Connect账号)
apple_id "your-apple-id@email.com"

# App Store Connect团队ID
itc_team_id "YOUR_ITC_TEAM_ID"

# 开发者团队ID
team_id "YOUR_DEVELOPER_TEAM_ID"

# 应用标识符
app_identifier "com.yourcompany.calculatorpro"

# 苹果开发者门户团队ID (可选)
team_name "Your Team Name"

# 包显示名称
app_name "Calculator Pro"

