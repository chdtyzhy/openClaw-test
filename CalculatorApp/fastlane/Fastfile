# Fastlane配置文件 - React Native iOS部署

default_platform(:ios)

platform :ios do
  # 设置全局变量
  APP_NAME = "Calculator Pro"
  APP_IDENTIFIER = "com.yourcompany.calculatorpro"
  ITC_TEAM_ID = "YOUR_ITC_TEAM_ID" # App Store Connect团队ID
  TEAM_ID = "YOUR_DEVELOPER_TEAM_ID" # 开发者团队ID
  
  # 开发环境lane
  desc "开发构建"
  lane :development do
    # 增加构建号
    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )
    
    # 构建开发版本
    gym(
      scheme: "CalculatorApp",
      export_method: "development",
      clean: true,
      output_directory: "./build"
    )
    
    # 上传到TestFlight (可选)
    # pilot(skip_submission: true)
  end
  
  # 测试环境lane
  desc "测试构建"
  lane :beta do
    # 确保在main分支
    ensure_git_branch(branch: 'main')
    
    # 增加构建号
    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )
    
    # 运行测试
    run_tests(
      scheme: "CalculatorApp",
      devices: ["iPhone 14"]
    )
    
    # 构建测试版本
    gym(
      scheme: "CalculatorApp",
      export_method: "app-store",
      clean: true,
      output_directory: "./build"
    )
    
    # 上传到TestFlight
    pilot(
      skip_waiting_for_build_processing: false,
      distribute_external: false
    )
    
    # 发送通知
    slack(
      message: "✅ Calculator Pro Beta #{get_build_number()} 已上传到TestFlight",
      success: true
    )
  end
  
  # 生产环境lane
  desc "发布到App Store"
  lane :release do
    # 确保在main分支
    ensure_git_branch(branch: 'main')
    
    # 增加版本号 (手动设置)
    # increment_version_number(version_number: "1.0.0")
    
    # 增加构建号
    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )
    
    # 运行测试
    run_tests(
      scheme: "CalculatorApp",
      devices: ["iPhone 14"]
    )
    
    # 构建发布版本
    gym(
      scheme: "CalculatorApp",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      }
    )
    
    # 上传到TestFlight进行最后测试
    pilot(
      skip_waiting_for_build_processing: false,
      distribute_external: false
    )
    
    # 提交到App Store审核
    deliver(
      skip_binary_upload: false,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: false
    )
    
    # 发送通知
    slack(
      message: "🚀 Calculator Pro #{get_version_number()} (#{get_build_number()}) 已提交到App Store审核",
      success: true
    )
  end
  
  # 截图lane
  desc "生成应用截图"
  lane :screenshots do
    # 清理旧的截图
    clean_screenshots
    
    # 捕获截图
    capture_screenshots(
      scheme: "CalculatorApp",
      devices: [
        "iPhone 14 Pro Max",
        "iPhone 14 Pro",
        "iPhone 14",
        "iPad Pro (12.9-inch) (6th generation)"
      ],
      languages: [
        "en-US",
        "zh-Hans"
      ],
      clear_previous_screenshots: true
    )
    
    # 添加设备边框
    frame_screenshots
    
    # 上传截图到App Store Connect
    upload_to_app_store(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true
    )
  end
  
  # 证书和配置文件管理
  desc "同步证书和配置文件"
  lane :match do
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      team_id: TEAM_ID,
      readonly: true
    )
  end
  
  # 初始化lane
  desc "初始化项目"
  lane :init do
    # 创建App Store Connect应用
    produce(
      username: ENV["APPLE_ID"],
      app_identifier: APP_IDENTIFIER,
      app_name: APP_NAME,
      language: "Simplified Chinese",
      app_version: "1.0",
      sku: "calculatorpro-#{Time.now.to_i}",
      team_id: ITC_TEAM_ID
    )
    
    # 初始化match
    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER],
      team_id: TEAM_ID,
      git_url: ENV["MATCH_GIT_URL"],
      readonly: false
    )
    
    puts "✅ 项目初始化完成"
    puts "App Identifier: #{APP_IDENTIFIER}"
    puts "下一步: 配置Fastlane环境变量"
  end
  
  # 环境检查lane
  desc "检查环境配置"
  lane :check_env do
    # 检查必要环境变量
    required_env_vars = [
      "FASTLANE_USER",
      "MATCH_PASSWORD",
      "MATCH_GIT_URL"
    ]
    
    missing_vars = required_env_vars.select { |var| ENV[var].nil? || ENV[var].empty? }
    
    if missing_vars.any?
      UI.user_error!("缺少环境变量: #{missing_vars.join(', ')}")
    else
      puts "✅ 所有必要环境变量已配置"
    end
    
    # 检查Xcode版本
    xcode_version = sh("xcodebuild -version | head -n1 | awk '{print $2}'").strip
    puts "Xcode版本: #{xcode_version}"
    
    # 检查Ruby版本
    ruby_version = sh("ruby --version").strip
    puts "Ruby版本: #{ruby_version}"
    
    # 检查Fastlane版本
    fastlane_version = sh("fastlane --version").strip
    puts "Fastlane版本: #{fastlane_version}"
  end
  
  # 帮助lane
  desc "显示帮助信息"
  lane :help do
    puts "可用lane:"
    puts "  fastlane ios development  - 开发构建"
    puts "  fastlane ios beta         - 测试构建 (上传到TestFlight)"
    puts "  fastlane ios release      - 发布构建 (提交到App Store)"
    puts "  fastlane ios screenshots  - 生成应用截图"
    puts "  fastlane ios match        - 同步证书"
    puts "  fastlane ios init         - 初始化项目"
    puts "  fastlane ios check_env    - 检查环境配置"
    puts "  fastlane ios help         - 显示帮助"
  end
  
  # 后处理lane
  after_all do |lane|
    # 构建成功后清理
    clean_build_artifacts
  end
  
  # 错误处理
  error do |lane, exception|
    # 发送错误通知
    slack(
      message: "❌ Calculator Pro构建失败: #{exception.message}",
      success: false
    )
  end
end